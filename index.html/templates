<!DOCTYPE html>
<html>
<head>
    <title>AI Study Assistant</title>

    <style>
        body {
            font-family: Arial;
            background: #f2f2f2;
            padding: 20px;
        }

        .container {
            width: 700px;
            margin: auto;
            background: white;
            padding: 25px;
            border-radius: 10px;
        }

        textarea {
            width: 100%;
            height: 150px;
            padding: 10px;
        }

        input {
            width: 100%;
            padding: 10px;
            margin-top: 10px;
        }

        button {
            padding: 10px 20px;
            margin-top: 10px;
            background: blue;
            color: white;
            border: none;
            cursor: pointer;
        }

        h2 {
            color: #333;
        }

        .output {
            background: #eee;
            padding: 15px;
            margin-top: 15px;
            border-radius: 5px;
        }
    </style>
</head>

<body>

<div class="container">

    <h1>AI Study Assistant</h1>

    <h2>Study Notes Summarizer</h2>

    <form method="POST">
        <textarea
            name="notes"
            placeholder="Paste study notes here..."
        ></textarea>

        <button type="submit">
            Summarize Notes
        </button>
    </form>

    {% if summary %}
    <div class="output">
        <h3>Summary:</h3>
        <p>{{ summary }}</p>
    </div>
    {% endif %}

    <hr>

    <h2>Ask Study Questions</h2>

    <form method="POST">
        <input
            type="text"
            name="question"
            placeholder="Ask a question..."
        >

        <button type="submit">
            Get Answer
        </button>
    </form>

    {% if answer %}
    <div class="output">
        <h3>Answer:</h3>
        <p>{{ answer }}</p>
    </div>
    {% endif %}

</div>

</body>
</html>
